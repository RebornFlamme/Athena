# Google Cloud — Compte de service avec rôle roles/speech.editor (ou roles/speech.client)
GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/la-cle-service-account.json

# ID du projet GCP (obligatoire)
GOOGLE_CLOUD_PROJECT=votre-gcp-project-id

# Région pour Chirp 3 (multi-région "us" — le seul qui supporte chirp_3 en streaming)
GOOGLE_CLOUD_REGION=us

# Supabase — écriture serveur (transcriptions + entités/événements extraits) via
# la clé SERVICE_ROLE (bypass RLS). Requis par le job de transcription ET
# l'extraction LLM. Project Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_SECRETE...

# Agent sémantique (job serveur) — clé API Gemini (format AQ. ou AIza)
GEMINI_API_KEY=...

# --- Modèles Gemini ---
# Flash : temps réel (agent_job). Défaut : gemini-3.5-flash.
GEMINI_MODEL_FLASH=gemini-3.5-flash
# Pro Preview : passes ponctuelles (extraction). Défaut : gemini-3.1-pro-preview.
GEMINI_MODEL_PRO=gemini-3.1-pro-preview
